{
  "uid": "ngx-otel-rust-overview",
  "title": "NGINX \u2014 Default vs ngx-otel-rust (OTel)",
  "tags": [
    "nginx",
    "otel",
    "ngx-otel-rust"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "refresh": "10s",
  "timezone": "",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(nginx_requests_total_sum, service_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
