# nginx-demo.conf.template — demo server for the Grafana visualisation stack.
#
# run-demo.sh substitutes template variables at startup and writes the result
# to .run/nginx.conf. Variables: MODULE_PATH (module .so/.dylib), PREFIX (run
# sandbox), OTEL_ENDPOINT (https:// TLS or http:// plaintext), TRUSTED_CA_LINE
# (trusted_certificate directive when DEMO_TLS=1, empty string otherwise).
#
# Shape:
#   :9400  front server, instrumented + exporting OTLP to the demo collector
#     /          -> 200 directly (exercises request/response body-size hists)
#     /api/*     -> proxy_pass to the local backend upstream (exercises the
#                   http.server.upstream.* metrics)
#     /big       -> larger response body (fills higher byte-size buckets)
#   :9401  backend upstream (plain nginx server block; the proxy target)

daemon off;
master_process on;
worker_processes 4;
error_log @PREFIX@/logs/error.log notice;
pid       @PREFIX@/logs/nginx.pid;

load_module @MODULE_PATH@;

events {
    worker_connections 1024;
}

http {
    # ── OTLP exporter: where and how telemetry is shipped ───────────────────
    otel_exporter {
        # Base collector endpoint. OTLP/HTTP appends /v1/{metrics,logs,traces};
        # OTLP/gRPC uses host:port only. @OTEL_ENDPOINT@ resolves to
        # https://127.0.0.1:14317 (TLS, default) or http://127.0.0.1:14317
        # (plaintext, when DEMO_TLS=0).
        endpoint @OTEL_ENDPOINT@;

        # CA bundle to verify the collector's TLS certificate (https:// only;
        # defaults to the system trust store). Injected here as the per-run demo
        # CA when DEMO_TLS=1 — the collector cert carries an IP SAN for 127.0.0.1.
@TRUSTED_CA_LINE@
        # mTLS — present a client certificate to the collector (both required
        # together; unused in the demo):
        #   ssl_certificate     /path/to/client.crt;
        #   ssl_certificate_key /path/to/client.key;
        # Collector-certificate verification; on by default. `off` is INSECURE
        # (testing only):
        #   ssl_verify on;
        # Per-signal endpoint overrides, used as-is with no path appended
        # (default: every signal goes to `endpoint` above):
        #   metrics_endpoint https://127.0.0.1:14317;
        #   logs_endpoint    https://127.0.0.1:14317;
        #   traces_endpoint  https://127.0.0.1:14317;
    }

    # ── General ─────────────────────────────────────────────────────────────
    # OTel resource service.name stamped on every exported signal.
    otel_service_name nginx-otel;
    # Export wire protocol: otlp_http (HTTP/1.1, default) | otlp_grpc (HTTP/2).
    otel_export_protocol otlp_grpc;
    # Extra OTel resource attributes, repeatable (unused in the demo):
    #   otel_resource_attr deployment.environment demo;
    # Static header on every export request, e.g. bearer auth to a hosted
    # collector (unused in the demo):
    #   otel_exporter_header authorization "Bearer <token>";

    # ── Metrics (on by default) ─────────────────────────────────────────────
    # Aggregation window: workers bump shared-memory slots continuously; the
    # exporter emits one aggregated point per series each interval. 2s here for a
    # lively demo dashboard; production is typically 10s or more.
    otel_metric_interval 2s;
    # The metrics shared-memory zone is auto-sized from worker_processes; there is
    # no operator-facing tuning directive.
    # Split the request-duration histogram by method × status-class × protocol
    # (bounded, low-cardinality attributes) so the dashboard can break p99 and
    # rate down by those dimensions. Status is the CLASS (2xx/4xx/5xx), not the
    # exact code.
    otel_metric_status_code_class on;

    # ── Logs (off unless set; orthogonal to nginx's own access_log/error_log) ─
    # Access log as summary + samples: a thin exception tail of full LogRecords
    # for operator-selected requests. Tail records carry url.path / status /
    # method / client.address. (Metric exemplars are separate — they ride trace
    # sampling below, one uniformly-sampled trace pointer per data point per cycle.)
    #
    # Pick WHICH requests get a tail LogRecord with `otel_log_export`, mirroring
    # nginx's own `access_log ... if=`. Forms: `on` (every request) · `if=$var`
    # (export when $var is truthy — non-empty and not "0") · `off`/omitted (no
    # records — the privacy-safe default). Here we export ONLY error responses
    # (HTTP status >= 400) by mapping $status to a truthy flag:
    map $status $otel_export_tail {
        default  "";      # 1xx/2xx/3xx → falsy → not exported
        ~^[45]   1;       # 4xx and 5xx → truthy → exported
    }
    otel_log_export if=$otel_export_tail;
    # The per-worker logs ring capacity backing the exception tail is fixed at
    # 512k; there is no operator-facing tuning directive.
    # Error log over OTLP: coalesced nginx.error LogRecords plus a companion error-
    # rate metric. Optional argument sets the minimum severity (defaults to error).
    otel_error_log warn;
    # Error coalescing is on by default; `off` streams verbatim (lossy under
    # load; unused in the demo):
    #   otel_error_log_coalesce off;

    # ── Traces (one OTel server span per request → Tempo) ───────────────────
    # Enable spans. Complex value: on | off | $var | split_clients (ratio
    # sampling). Valid in http / server / location (innermost wins).
    otel_trace on;
    # Inbound W3C traceparent handling: ignore | extract (default) | inject |
    # propagate. `ignore` starts a fresh ROOT span per request — the demo load
    # generator sends a synthetic parent that never reaches Tempo, so ignoring it
    # keeps every trace a clean, searchable root. Duration-histogram exemplars
    # carry the span's trace_id, enabling metric → exemplar → Tempo → Loki drill-down.
    otel_trace_context ignore;
    # Custom span attribute(s), repeatable. Valid in http / server / location.
    otel_span_attr deployment.environment demo;
    # Per-location span name override (default is the matched location/route;
    # shown per location below):
    #   otel_span_name "API $request_method";
    #
    # Module-provided nginx variables (usable in log_format, map, etc.):
    #   $otel_trace_id        the current span's trace ID (or empty if unsampled)
    #   $otel_parent_sampled  whether the inbound traceparent was sampled

    # Backend the front server proxies to (populates upstream.* metrics).
    upstream demo_backend {
        # The shared-memory `zone` names this upstream — the module keys the
        # per-upstream latency series (nginx.upstream.zone) on it. Without a
        # zone there is no name to attribute to, so the by-upstream panel stays
        # empty. (NGINX Plus model; `zone` is OSS since 1.9.0.)
        zone demo_backend 1m;
        server 127.0.0.1:9401;
        keepalive 16;
    }

    # ── Front (instrumented) server ───────────────────────────────────────
    server {
        listen 127.0.0.1:9400;

        location / {
            return 200 "ngx-otel-rust demo: ok\n";
        }
        # Error endpoints so the by-status-class metric split
        # (otel_metric_status_code_class) shows 4xx/5xx, not just 2xx — drives
        # the "request rate by status class" panel.
        location = /client-error {
            return 404 "not found\n";
        }
        location = /server-error {
            return 500 "boom\n";
        }

        location /big {
            # Larger body to spread the response-body-size histogram into
            # higher buckets. (~1 KiB of filler.)
            return 200 "\n";
        }

        location /api/ {
            # Per-location span name override (otel_span_name) — uncomment to
            # name these spans e.g. "API GET" instead of the default route:
            #   otel_span_name "API $request_method";
            proxy_pass http://demo_backend/;
            proxy_http_version 1.1;
            proxy_set_header Connection "";
        }

        # Proxy to a port with nothing listening → real "connect() failed"
        # nginx error_log lines (error level). These exercise the OTel ERROR
        # log signal (coalesced nginx.error LogRecords), distinct from the
        # access tail above — drives the dashboard's "Error Log" panel.
        location /backend-down {
            proxy_pass http://127.0.0.1:9099;
        }
    }

    # ── Backend upstream ──────────────────────────────────────────────────
    server {
        listen 127.0.0.1:9401;
        location / {
            return 200 "backend response\n";
        }
    }

    # ── TLS demo servers (Serving-certificates dashboard panel) ──────────
    # Certs are generated per-run by run-demo.sh into @PREFIX@/certs:
    #   short.crt  ~1 h (24 h on LibreSSL fallback) → red in the panel,
    #              ngx_otel.tls.certificate.time_to_expiration counts down
    #   long.crt   90 d                             → green
    # No traffic needed: cert metrics are collected at config time from the
    # live SSL_CTX (TELEMETRY_MODEL.md "ngx_otel.tls.certificate.*").
    server {
        listen 127.0.0.1:9443 ssl;
        server_name demo-short.local;
        ssl_certificate     @PREFIX@/certs/short.crt;
        ssl_certificate_key @PREFIX@/certs/short.key;
        location / { return 200 "tls-short\n"; }
    }
    server {
        listen 127.0.0.1:9444 ssl;
        server_name demo-long.local;
        ssl_certificate     @PREFIX@/certs/long.crt;
        ssl_certificate_key @PREFIX@/certs/long.key;
        location / { return 200 "tls-long\n"; }
    }
}
